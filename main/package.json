{
  "name": "naikit",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc && vite build",
    "clean": "rm -rf dist",
    "package": "npm run build && cd dist && zip -r ../naikit-v$npm_package_version.zip .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "immer": "^latest",
    "lodash-es": "^latest",
    "nanoid": "^latest",
    "react": "^latest",
    "react-dom": "^latest",
    "tailwindcss": "^latest",
    "webext-bridge": "^latest",
    "zod": "^latest",
    "zustand": "^latest"
  },
  "devDependencies": {
    "@samrum/vite-plugin-web-extension": "^latest",
    "@tailwindcss/forms": "^latest",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/chrome": "^latest",
    "@types/lodash-es": "^latest",
    "@types/node": "^latest",
    "@types/react": "^latest",
    "@types/react-dom": "^latest",
    "@vitejs/plugin-react": "^latest",
    "autoprefixer": "^latest",
    "eslint-plugin-testing-library": "^7.1.1",
    "eslint-plugin-vitest": "^0.5.4",
    "happy-dom": "^17.4.2",
    "postcss": "^latest",
    "typescript": "^latest",
    "vite": "^latest",
    "vitest": "^3.0.8"
  }
}